{
  "name": "@leantli/agent-handoff",
  "version": "0.6.3",
  "description": "Shared vault handoff memory for coding agents.",
  "type": "module",
  "license": "MIT",
  "author": "agent-handoff contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leantli/agent-handoff.git"
  },
  "bugs": {
    "url": "https://github.com/leantli/agent-handoff/issues"
  },
  "homepage": "https://github.com/leantli/agent-handoff#readme",
  "bin": {
    "agent-handoff": "dist/bin.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "resources",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "prepublishOnly": "npm run typecheck && npm test && npm run build && npm run smoke:import",
    "smoke:import": "node -e \"import('./dist/index.js').then((m) => { if (!m.enableHandoff || !m.installSkill || !m.syncVault) process.exit(1); })\"",
    "test": "vitest run",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json"
  },
  "keywords": [
    "ai",
    "agents",
    "codex",
    "claude-code",
    "handoff",
    "context"
  ],
  "engines": {
    "node": ">=22.12.0"
  },
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "typescript": "^5.4.0",
    "vitest": "^4.1.6"
  }
}
